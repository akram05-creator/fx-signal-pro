{
  "version": 2,
  "builds": [
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/prices",   "dest": "/api/prices.js"   },
    { "src": "/api/groq",     "dest": "/api/groq.js"     },
    { "src": "/api/telegram", "dest": "/api/telegram.js" },
    { "src": "/(.*)",         "dest": "/public/index.html" }
  ]
}
